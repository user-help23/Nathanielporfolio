# Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: Never commit .env.local file to version control!

# WhatsApp Configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890

# Contact Email Configuration
CONTACT_EMAIL=your-email@example.com

# Email Service (if using Resend or SendGrid)
# RESEND_API_KEY=your_resend_api_key_here
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Nathaniel Patrick

# Environment
NODE_ENV=development

# Notes:
# - For Next.js, use .env.local for local development
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# - Never share API keys or secrets
# - Keep sensitive keys in .env.local (not committed to git)
