# Environment Variables Example
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control!

# Email Configuration (if using email service)
EMAIL_SERVICE_ID=your_emailjs_service_id_here
EMAIL_TEMPLATE_ID=your_emailjs_template_id_here
EMAIL_PUBLIC_KEY=your_emailjs_public_key_here

# Backend API Configuration
REACT_APP_API_URL=http://localhost:3001
REACT_APP_API_KEY=your_api_key_here

# Third-party API Keys
GITHUB_API_KEY=ghp_xxxxxxxxxxxx
LINKEDIN_API_KEY=your_linkedin_api_key

# Analytics (optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Environment
NODE_ENV=development
REACT_APP_ENV=development

# Notes:
# - This file is for reference only (example template)
# - Create a .env file with your actual values
# - The .env file is in .gitignore (won't be committed)
# - Never share API keys or secrets
# - For frontend projects, only use non-sensitive configuration
# - For sensitive data, use backend environment variables instead
